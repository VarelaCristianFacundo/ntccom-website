---
// Contact Hero Section
// ------------
// Description: A hero section with a contact form

// Components
// - Layout
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - UI
import Form from '../contact/BasicForm.astro'

// Props
type Props = {
	id?: string
	title?: string
	text?: string
	classes?: string
}
const { id, title, text, classes } = Astro.props
---

<Section id={id} classes={classes}>
	<Row>
		<Col span="6">
			<header class="max-w-xl">
				<h1 set:html={title} />
				<p class="text-lg leading-relaxed">{text}</p>
			</header>

			<!-- Información de contacto -->
			<div class="mt-6 space-y-2">
				<p class="text-lg font-semibold text-neutral-800 dark:text-neutral-200">Contact Details</p>

				<p class="text-lg font-semibold text-neutral-800 dark:text-neutral-200">
					Adress: <span class="text-primary-500"
						>5435 SW 191st Terrace, Miramar, FL 33029</span
					>
				</p>
				<p class="text-lg font-semibold text-neutral-800 dark:text-neutral-200">
					Tel.: <a href="tel:+17867315657" class="text-primary-500 hover:underline"
						>(786) 731 5657</a
					>
				</p>
				<p class="text-lg font-semibold text-neutral-800 dark:text-neutral-200">
					Email: <a href="mailto:alejandro@ntccom.net" class="text-primary-500 hover:underline"
						>alejandro@ntccom.net</a
					>
				</p>
			</div>

			<!-- Insertamos el mapa de Google Maps aquí -->
			<div class="mt-8 max-w-xl">
				<iframe
					src="https://maps.google.com/maps?q=5435+SW+191st+Terrace,+Miramar,+FL+33029&output=embed"
					width="100%"
					height="100%"
					style="border:0;"
					allowfullscreen=""
					loading="lazy"
					referrerpolicy="no-referrer-when-downgrade"
				>
				</iframe>
			</div>
		</Col>
		<Col span="6" classes="relative">
			<Form classes="max-w-xl" />
		</Col>
	</Row>
</Section>
